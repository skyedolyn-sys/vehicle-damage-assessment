# Template for local secrets — copy to .env and fill in real values.
# .env is git-ignored; .env.example is committed so a new checkout knows
# what keys are required.
#
# Bootstrap the database on first run with:
#     python manage.py migrate

# ── Required: minimax (vision LLM) credentials ──────────────────────────
MINIMAX_API_KEY=sk-cp-replace-me
MINIMAX_BASE_URL=https://api.minimaxi.com/v1/chat/completions
MINIMAX_MODEL=MiniMax-M3

# ── Django core ──────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-me-with-django-insecure-default
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ── HTTP serving ─────────────────────────────────────────────────────────
BASE_URL=http://localhost:8000

# ── Pipeline tuning ──────────────────────────────────────────────────────
# PHOTO_LOCATOR_BATCH_SIZE: photos per locator LLM call (default 2)
# MAX_CONCURRENT_API_CALLS: parallel LLM calls (default 2)
# REQUEST_TIMEOUT: per-call seconds (default 300)
# IMAGE_MAX_WIDTH: input image width fed to the vision model in pixels
#                  (default 1024 — 512 cuts tokens ~4× but breaks small damage)
# IMAGE_QUALITY: JPEG quality 0-100 (default 85)
PHOTO_LOCATOR_BATCH_SIZE=2
MAX_CONCURRENT_API_CALLS=2
REQUEST_TIMEOUT=300
IMAGE_MAX_WIDTH=1024
IMAGE_QUALITY=85

# ── Optional: agent file logs ────────────────────────────────────────────
# Directory the per-agent log files go to.  Defaults to <BASE_DIR>/logs
# if unset.  Set this to a writable path on the deploy host when running
# under systemd / docker / sandboxed processes where $HOME is read-only.
# VEHICLE_DAMAGE_LOG_DIR=/var/log/vehicle_damage_assessment